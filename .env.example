# ===================================
# Proyecto Intelligent - Environment Variables Example
# ===================================
#
# IMPORTANTE:
# 1. Copia este archivo y renómbralo a .env
# 2. Reemplaza los valores con tus credenciales reales
# 3. NUNCA subas el archivo .env a GitHub
#

# ============ Database Configuration ============
POSTGRES_DB=backend_intelligent_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password_in_production
DB_HOST=db
DB_PORT=5432

# ============ Django Backend Configuration ============
DEBUG=True
SECRET_KEY=change-this-secret-key-generate-a-new-one-for-production
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://frontend:3000

# ============ Frontend Configuration ============
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_FACE_RECOGNITION_URL=http://localhost:8080

# ============ Face Recognition Service ============
PORT=8080
LOG_LEVEL=info
